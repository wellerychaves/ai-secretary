# =============================================================================
# SECRETÁRIA ELETRÔNICA IA - Configurações de Ambiente
# =============================================================================
# ATENÇÃO: Este arquivo contém informações sensíveis!
# - NÃO commitar no Git (adicionar ao .gitignore)
# - Usar senhas fortes em produção
# - Manter backup seguro das credenciais
# =============================================================================

# -----------------------------------------------------------------------------
# INFRAESTRUTURA COMPARTILHADA
# -----------------------------------------------------------------------------

# PostgreSQL - Banco de dados principal (usado pelo postgres container e healthcheck)
POSTGRES_DB=main_db
POSTGRES_USER=admin
POSTGRES_PASSWORD=mysecretpassword

# Redis - Cache e filas
REDIS_PASSWORD=myredispassword

# -----------------------------------------------------------------------------
# CHATWOOT - Atendimento ao Cliente
# -----------------------------------------------------------------------------

# Ambiente
NODE_ENV=production
RAILS_ENV=production
INSTALLATION_ENV=docker

# URLs
FRONTEND_URL=http://localhost:3000

# Storage
ACTIVE_STORAGE_SERVICE=local

# Segurança
CHATWOOT_SECRET_KEY_BASE=f3db1c88e7946cbae1f65a07523b329b782cda30fce19e94c41a1f0c95cbb37571304d6c8347f6603a052d0418413b076a7595b27910d2814f8ac213c68ecb0b

# Database dedicado (credenciais usadas pelo init-db.sh no postgres)
CHATWOOT_POSTGRES_DB=chatwoot_db
CHATWOOT_POSTGRES_USER=chatwoot_user
CHATWOOT_POSTGRES_PASSWORD=chatwoot_password

# DATABASE_URL e REDIS_URL completas — necessário pois o compose não monta mais via environment:
DATABASE_URL=postgresql://chatwoot_user:chatwoot_password@postgres:5432/chatwoot_db
REDIS_URL=redis://:myredispassword@redis:6379/0

# Webhooks locais (desenvolvimento — remover em produção)
SSRF_IP_RANGE_BLACKLIST=

# Opcional: Configurações adicionais Chatwoot
# MAILER_SENDER_EMAIL=secretaria@seudominio.com
# SMTP_ADDRESS=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=seu-email@gmail.com
# SMTP_PASSWORD=sua-senha-app

# -----------------------------------------------------------------------------
# EVOLUTION API - Gateway WhatsApp
# -----------------------------------------------------------------------------

# Porta de acesso
EVOLUTION_API_PORT=8080

# Autenticação
AUTHENTICATION_API_KEY=mizera

# Database dedicado (credenciais usadas pelo init-db.sh no postgres)
EVOLUTION_POSTGRES_DB=evolution_db
EVOLUTION_POSTGRES_USER=evolution_user
EVOLUTION_POSTGRES_PASSWORD=evolution_password

# DATABASE_CONNECTION_URI completa — necessário pois o compose não monta mais via environment:
DATABASE_CONNECTION_URI=postgresql://evolution_user:evolution_password@postgres:5432/evolution_db

# Database - Configurações
DATABASE_ENABLED=true
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_CLIENT_NAME=evolution_exchange

# Database - O que salvar
DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true

# Cache Redis
CACHE_REDIS_ENABLED=true

# CACHE_REDIS_URI completa — necessário pois o compose não monta mais via environment:
CACHE_REDIS_URI=redis://:myredispassword@redis:6379

# WhatsApp - Versão do client
CONFIG_SESSION_PHONE_VERSION=2.3000.1030429772

# Opcional: Webhooks e integrações
# WEBHOOK_GLOBAL_URL=http://localhost:5678/webhook/evolution
# WEBHOOK_GLOBAL_ENABLED=true
# WEBHOOK_GLOBAL_WEBHOOK_BY_EVENTS=true

# Opcional: Chatwoot Integration
# CHATWOOT_ENABLED=true
# CHATWOOT_BASE_URL=http://chatwoot-rails:3000
# CHATWOOT_API_KEY=sua-api-key-aqui

# -----------------------------------------------------------------------------
# N8N - Automação e Fluxos de IA
# -----------------------------------------------------------------------------

# Porta de acesso
N8N_PORT=5678

# Database dedicado (credenciais usadas pelo init-db.sh no postgres)
N8N_POSTGRES_DB=n8n_db
N8N_POSTGRES_USER=n8n_user
N8N_POSTGRES_PASSWORD=n8n_password

# Configurações de conexão completas — necessário pois o compose não monta mais via environment:
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n_db
DB_POSTGRESDB_USER=n8n_user
DB_POSTGRESDB_PASSWORD=n8n_password

# URLs e Protocol
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678/

# Timezone
GENERIC_TIMEZONE=America/Sao_Paulo
TZ=America/Sao_Paulo

# Opcional: Segurança N8N (recomendado em produção)
# N8N_BASIC_AUTH_ACTIVE=true
# N8N_BASIC_AUTH_USER=admin
# N8N_BASIC_AUTH_PASSWORD=senha-segura-aqui

# Opcional: Encryption Key (gerar com: openssl rand -hex 32)
# N8N_ENCRYPTION_KEY=sua-chave-de-32-caracteres-hexadecimais

# Opcional: APIs de IA (adicionar conforme necessário)
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GOOGLE_AI_API_KEY=...

# =============================================================================
# NOTAS DE DESENVOLVIMENTO
# =============================================================================
#
# Para gerar novas chaves secretas:
# - SECRET_KEY_BASE: openssl rand -hex 64
# - N8N_ENCRYPTION_KEY: openssl rand -hex 32
# - AUTHENTICATION_API_KEY: openssl rand -hex 16
#
# ATENÇÃO ao atualizar senhas no .env:
# As variáveis abaixo contêm a senha embutida na URI — atualize em ambos os lugares:
#   - REDIS_PASSWORD        → REDIS_URL, CACHE_REDIS_URI
#   - CHATWOOT_POSTGRES_*   → DATABASE_URL
#   - EVOLUTION_POSTGRES_*  → DATABASE_CONNECTION_URI
#   - N8N_POSTGRES_*        → DB_POSTGRESDB_USER / DB_POSTGRESDB_PASSWORD / DB_POSTGRESDB_DATABASE
#
# Para trocar para produção:
# 1. Alterar todas as senhas
# 2. Configurar FRONTEND_URL com domínio real
# 3. Habilitar autenticação no N8N
# 4. Remover SSRF_IP_RANGE_BLACKLIST
# 5. Configurar SSL/HTTPS
#
# =============================================================================
